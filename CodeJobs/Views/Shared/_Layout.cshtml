<!DOCTYPE html>
<html>
<head>
    <title>@ViewBag.Title</title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="@Url.Content("~/Content/bootstrap.min.css")" />

    <!-- Vendor styles -->
    <link rel="stylesheet" href="@Url.Content("~/vendor/fontawesome/css/font-awesome.css")" />
    <link rel="stylesheet" href="@Url.Content("~/vendor/metisMenu/dist/metisMenu.css")" />
    <link rel="stylesheet" href="@Url.Content("~/vendor/animate.css/animate.css")" />
    <link rel="stylesheet" href="@Url.Content("~/vendor/bootstrap/dist/css/bootstrap.css")" />

    <!-- App styles -->
    <link rel="stylesheet" href="@Url.Content("~/fonts/pe-icon-7-stroke/css/pe-icon-7-stroke.css")" />
    <link rel="stylesheet" href="@Url.Content("~/fonts/pe-icon-7-stroke/css/helper.css")" />
    <link rel="stylesheet" href="@Url.Content("~/styles/style.css")" />

    @RenderSection("Styles", required: false)
</head>

<body class="blank">
    <div class="container">
        <div class="color-line"></div>

        <div class="back-link">
            <a href="@Url.Content("~/Index.html")" class="btn btn-primary">Back to Dashboard</a>
        </div>

        @RenderBody()
    </div>

    <!-- Vendor scripts -->
    <script src="@Url.Content("~/vendor/jquery/dist/jquery.min.js")"></script>
    <script src="@Url.Content("~/vendor/jquery-ui/jquery-ui.min.js")"></script>
    <script src="@Url.Content("~/vendor/slimScroll/jquery.slimscroll.min.js")"></script>
    <script src="@Url.Content("~/vendor/bootstrap/dist/js/bootstrap.min.js")"></script>
    <script src="@Url.Content("~/vendor/metisMenu/dist/metisMenu.min.js")"></script>
    <script src="@Url.Content("~/vendor/iCheck/icheck.min.js")"></script>
    <script src="@Url.Content("~/vendor/sparkline/index.js")"></script>

    <!-- App scripts -->
    <script src="@Url.Content("~/scripts/homer.js")"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
